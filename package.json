{
  "name": "pro-soccer-online-backend",
  "version": "1.0.0",
  "description": "Backend API para Pro Soccer Online 2",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed-postgres.js",
    "seed-db": "node scripts/seed-db.js",
    "test": "jest",
    "deploy": "npm run seed && npm start",
    "prisma:setup": "chmod +x scripts/setup-prisma.sh && ./scripts/setup-prisma.sh",
    "prisma:push": "npx prisma db push",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:seed": "npm run seed-db"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^4.16.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "csurf": "^1.11.0",
    "discord.js": "^14.26.2",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-enforces-ssl": "^1.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "express-session": "^1.17.3",
    "express-slow-down": "^1.6.0",
    "express-validator": "^6.15.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
