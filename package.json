  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/preset-react": "^7.22.15",
    "autoprefixer": "^10.4.16",
    "jest": "^29.5.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "supertest": "^6.3.0",
    "tailwindcss": "^3.3.6"
