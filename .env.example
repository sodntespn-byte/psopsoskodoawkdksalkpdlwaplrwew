# ==========================================
# PSO Brasil - Environment Variables
# Configure estas variáveis no painel da Square Cloud
# ==========================================

# Server Configuration
NODE_ENV=production
PORT=80

# Database (PostgreSQL na Square Cloud)
# URL completa com SSL - obtenha no painel Database da Square Cloud
DATABASE_URL=postgresql://usuario:senha@host:porta/database?sslmode=require

# Ou configure individualmente:
DB_HOST=sua-database.squareweb.app
DB_PORT=7196
DB_NAME=squarecloud
DB_USER=squarecloud
DB_PASSWORD=sua_senha_aqui
DB_SSL=true

# Security
JWT_SECRET=seu_jwt_secret_aqui_minimo_32_caracteres
SESSION_SECRET=seu_session_secret_aqui
ENCRYPTION_KEY=sua_chave_de_criptografia_aqui

# Discord Bot
DISCORD_BOT_TOKEN=seu_token_do_bot_discord
DISCORD_GUILD_ID=seu_guild_id

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=seu_client_id_google
GOOGLE_CLIENT_SECRET=seu_client_secret_google
GOOGLE_CALLBACK_URL=https://seu-dominio.squareweb.app/auth/google/callback

# CORS
ALLOWED_ORIGINS=https://seu-dominio.squareweb.app,http://localhost:3000

# Email (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
