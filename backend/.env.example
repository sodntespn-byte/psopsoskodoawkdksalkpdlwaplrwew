# Configurações do Servidor
NODE_ENV=development
PORT=3000

# Configurações do Banco de Dados PostgreSQL - Square Cloud
DATABASE_URL=postgresql://username:password@localhost:5432/pso_brasil
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pso_brasil
DB_USER=username
DB_PASSWORD=password
DB_DIALECT=postgres

# Configurações de Segurança
ENCRYPTION_KEY="9S1t1L?4`;MytM=,z/Q~R=69!>WO?X0M"
WEBHOOK_HMAC_SECRET="super_secret_hmac_key_here"
TRANSFER_SECRET_KEY="webhook_secret_key_here"
JWT_SECRET="your_jwt_secret_key"

# Configurações de Discord
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_WEBHOOK_URL="your_discord_webhook_url"
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_GUILD_ID="your_discord_guild_id"

# Configurações de CORS
CORS_ORIGIN=http://localhost:8000
ALLOWED_ORIGINS="http://localhost:3000,https://your-domain.com"
TRUSTED_PROXIES="cloudflare"

# Configurações de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BLOCK_DURATION=1800000

# Configurações de WebSocket
WEBSOCKET_PORT=3001
WEBSOCKET_CORS_ORIGIN="http://localhost:3000"
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Configurações de Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Configurações de Session
SESSION_SECRET=prosoccer_session_secret_2030_squarecloud

# Configurações de Cache (Bot)
CACHE_TTL=300000
CACHE_MAX_SIZE=1000

# Configurações de Sharding (Bot Discord)
TOTAL_SHARDS=auto
SHARD_ID=0

# Configurações de Logs
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Configurações de Analytics
GOOGLE_ANALYTICS_ID=

# Configurações de Monitoramento
SENTRY_DSN=
METRICS_PORT=9090
HEALTH_CHECK_PATH=/api/health

# Configurações SSL para Square Cloud
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CA_PATH=
SSL_MODE=require

# Configurações de Deploy SquareCloud
BASE_URL=https://your-app.squarecloud.app
SQUARECLOUD_APP_ID=

# Bot Owner (para comandos administrativos privilegiados)
BOT_OWNER_ID=your_discord_user_id

# Configurações Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
