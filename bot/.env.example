# PSO BRASIL - Discord Bot Configuration
# Copie este arquivo para .env e preencha os valores

# Discord Bot Token
DISCORD_BOT_TOKEN=seu_token_aqui

# Discord Application ID
DISCORD_CLIENT_ID=1491627709552656546

# Admin User ID (seu ID do Discord)
ADMIN_USER_ID=123456789012345678

# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# URLs
STAGING_URL=https://staging.psobrasil.com
PRODUCTION_URL=https://psobrasil.com

# Webhook URL para notificações #jornal-pso
JORNAL_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# Puppeteer settings
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox

# Node Environment
NODE_ENV=production
